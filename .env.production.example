# Production Environment Configuration
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-generate-a-random-string

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Jira Configuration
JIRA_BASE_URL=https://jira.hlklemove.com
JIRA_PAT=your-jira-personal-access-token

# Confluence Configuration
CONFLUENCE_BASE_URL=https://confluence.hlklemove.com
CONFLUENCE_PAT=your-confluence-personal-access-token

# MCP Server Configuration (if using ALM MCP)
MCP_SERVER_NAME=ALM_MCP_STDIO
MCP_COMMAND=node
MCP_DIST_PATH=C:\Tools\alm-mcp-stdio\dist\index.js

# Security Notes:
# - Generate a strong SECRET_KEY using: python -c "import secrets; print(secrets.token_hex(32))"
# - Never commit .env file to version control
# - Keep your API keys and tokens secure
# - Restrict file permissions on .env file
